CountdownDesc.TextColor3 = Color_Red
CountdownDesc.TextSize = 12
CountdownDesc.ZIndex = 5

-- Countdown Logic
task.spawn(function()
    while MainFrame.Parent do
        local currentTime = os.time()
        local timeLeft = TargetUnixTime - currentTime
        
        if timeLeft <= 0 then
            CountdownText.Text = "UPDATE DEPLOYED!"
            CountdownText.TextColor3 = Color3.fromRGB(50, 255, 50) -- Green when ready
            CountdownDesc.Text = "PLEASE RE-EXECUTE THE SCRIPT"
            CountdownDesc.TextColor3 = Color3.fromRGB(200, 200, 200)
            break
        else
            local d = math.floor(timeLeft / 86400)
            local h = math.floor((timeLeft % 86400) / 3600)
            local m = math.floor((timeLeft % 3600) / 60)
            local s = timeLeft % 60
            
            -- Formatting to always show 2 digits (e.g., 05 instead of 5)
            CountdownText.Text = string.format("%02d:%02d:%02d:%02d", d, h, m, s)
        end
        task.wait(1)
    end
end)

