-- --- TRANSLATION LOGIC ---
local CurrentLanguage = "PT"
local isFinished = false
local LangButtons = {}

local function SetLanguage(lang)
    CurrentLanguage = lang
    local data = Translations[lang]
    if not data then return end
    
    Title.Text = data.Title
    Desc.Text = data.Desc
    BtnDiscord.Text = data.Discord
    BtnClose.Text = data.Close
    
    if isFinished then
        CountdownText.Text = data.Deployed
        CountdownDesc.Text = data.Reexecute
    else
        CountdownDesc.Text = data.CountdownDesc
    end
    
    -- Visual update on language buttons
    for name, btn in pairs(LangButtons) do
        if name == lang then
            btn.TextColor3 = Color_Red
            btn.BackgroundTransparency = 0.8
        else
            btn.TextColor3 = Color3.fromRGB(150, 150, 150)
            btn.BackgroundTransparency = 0.95
        end
    end
end

-- Create Language Buttons
