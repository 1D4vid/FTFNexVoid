-- Target Time setup
-- 17:00 BRT (Brasília Time) is equal to 20:00 UTC.
-- We use UTC to ensure the countdown is correct regardless of the player's local timezone.
local TargetUnixTime = DateTime.fromUniversalTime(2026, 4, 26, 20, 0, 0).UnixTimestamp 

-- Image requested
local ImageID = "rbxassetid://14875954674"

-- Theme Colors
local Color_Black = Color3.fromRGB(10, 10, 10)      -- Deep Black
local Color_Red   = Color3.fromRGB(220, 20, 20)     -- Blood Red
