-- --- COUNTDOWN LOGIC ---
task.spawn(function()
    while MainFrame.Parent do
        local currentTime = os.time()
        local timeLeft = TargetUnixTime - currentTime
        
        if timeLeft <= 0 then
            isFinished = true
            local data = Translations[CurrentLanguage]
            CountdownText.Text = data.Deployed
            CountdownText.TextColor3 = Color3.fromRGB(50, 255, 50) -- Green when ready
            CountdownDesc.Text = data.Reexecute
            CountdownDesc.TextColor3 = Color3.fromRGB(200, 200, 200)
        else
            isFinished = false
            local d = math.floor(timeLeft / 86400)
            local h = math.floor((timeLeft % 86400) / 3600)
            local m = math.floor((timeLeft % 3600) / 60)
            local s = timeLeft % 60
            
            CountdownText.Text = string.format("%02d:%02d:%02d:%02d", d, h, m, s)
            CountdownText.TextColor3 = Color_Text
            CountdownDesc.Text = Translations[CurrentLanguage].CountdownDesc
            CountdownDesc.TextColor3 = Color_Red
        end
        task.wait(1)
    end
end)

-- --- DRAGGABLE LOGIC ---
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

