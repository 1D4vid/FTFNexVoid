local function SetLanguage(lang, activeBtn)
    local t = Translations[lang]
    Title.Text = t.Title
    Desc.Text = t.Desc
    CountdownDesc.Text = t.CountDesc
    BtnClose.Text = t.Close
    
    -- Reset all colors
    btnEN.TextColor3 = Color_Text
    btnPT.TextColor3 = Color_Text
    btnES.TextColor3 = Color_Text
    
    -- Highlight selected language
    activeBtn.TextColor3 = Color_Red
end

