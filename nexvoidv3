    Library:CreateToggle(HighlightPage, "Esp Doors", false, function(state) 
        showDoorESP = state
        if state then
            local COLOR_OPEN = Color3.fromRGB(0, 255, 0)
            local COLOR_CLOSED = Color3.fromRGB(255, 0, 0)

            for _, model in ipairs(CachedDoors) do
                if model and model.Parent then
                    local highlight = model:FindFirstChild("DoorESP_FTF")
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "DoorESP_FTF"
                        highlight.Adornee = model
                        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        highlight.FillTransparency = 0.5
                        highlight.OutlineTransparency = 0.2
                        highlight.FillColor = COLOR_CLOSED
                        highlight.OutlineColor = EspConfig.OutlineDoor
                        highlight.Parent = model
                    end

                    for _, child in ipairs(model:GetDescendants()) do
                        if child:IsA("BasePart") and (child.Name:match("Door") or child.Name == "Part") then
                            if child.Size.Y > 3 and not trackedDoors[child] then
                                trackedDoors[child] = {
                                    esp = highlight,
                                    initialCFrame = child.CFrame
                                }
                            end
                        end
                    end
                end
            end

            doorEspLoop = task.spawn(function()
                while showDoorESP and task.wait(0.2) do
                    for part, data in pairs(trackedDoors) do
                        if part and part.Parent and data.esp then
                            local currentCF = part.CFrame
                            local distMoved = (currentCF.Position - data.initialCFrame.Position).Magnitude
                            local isOpen = not part.CanCollide or distMoved > 0.5 or part.Transparency > 0.8
                            data.esp.FillColor = isOpen and COLOR_OPEN or COLOR_CLOSED
                            data.esp.OutlineColor = EspConfig.OutlineDoor
                        else
                            trackedDoors[part] = nil
                        end
                    end
                end
            end)
        else
            if doorEspLoop then task.cancel(doorEspLoop) end
            for _, model in ipairs(CachedDoors) do
                if model then
                    local h = model:FindFirstChild("DoorESP_FTF")
                    if h then h:Destroy() end
                end
            end
            table.clear(trackedDoors)
        end
    end)
    
