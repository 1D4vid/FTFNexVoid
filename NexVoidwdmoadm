-- Hover: Fica branco, letra preta
CloseBtn.MouseEnter:Connect(function()
    TweenService:Create(CloseBtn, TweenInfo.new(0.3), {
        BackgroundTransparency = 0,
        TextColor3 = Color3.fromRGB(0, 0, 0)
    }):Play()
end)

-- Sai do Hover: Volta a ser apenas a borda
CloseBtn.MouseLeave:Connect(function()
    TweenService:Create(CloseBtn, TweenInfo.new(0.3), {
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(255, 255, 255)
    }):Play()
end)

-- Fechar Menu
CloseBtn.MouseButton1Click:Connect(function()
    local fecharAnim = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
    
    TweenService:Create(MainPanel, fecharAnim, {Position = UDim2.new(0.5, 0, 0.53, 0), BackgroundTransparency = 1}):Play()
    TweenService:Create(PanelStroke, fecharAnim, {Transparency = 1}):Play()
    TweenService:Create(BackgroundImage, fecharAnim, {ImageTransparency = 1}):Play()
    TweenService:Create(ImageOverlay, fecharAnim, {BackgroundTransparency = 1}):Play()
    TweenService:Create(Title, fecharAnim, {TextTransparency = 1}):Play()
    TweenService:Create(TextEN, fecharAnim, {TextTransparency = 1}):Play()
    TweenService:Create(TextBR, fecharAnim, {TextTransparency = 1}):Play()
    TweenService:Create(CloseBtn, fecharAnim, {TextTransparency = 1, BackgroundTransparency = 1}):Play()
    TweenService:Create(BtnStroke, fecharAnim, {Transparency = 1}):Play()
    TweenService:Create(Divider, fecharAnim, {Size = UDim2.new(0, 0, 0, 1)}):Play()
    
    TweenService:Create(DarkScreen, fecharAnim, {BackgroundTransparency = 1}):Play()
    TweenService:Create(Blur, fecharAnim, {Size = 0}):Play()
    
    task.wait(0.5)
    ScreenGui:Destroy()
    Blur:Destroy()
end)
